<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="720" prefWidth="1100" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.countepiphany.controller.TransaksiController">

    <HBox alignment="CENTER_LEFT" styleClass="header-bar">
        <VBox>
            <Label style="-fx-font-style:italic;" styleClass="header-title" text="Count" />
            <Label style="-fx-font-style:italic;-fx-font-size:18px;" styleClass="header-title" text="Epiphany" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Label styleClass="header-tagline" text="Transaksi Penjualan" />
    </HBox>

    <HBox VBox.vgrow="ALWAYS">

        <VBox alignment="TOP_CENTER" spacing="6" styleClass="sidebar">
            <Button onAction="#gotoTransaksi" styleClass="nav-button" text="Transaksi" />
            <Button onAction="#gotoInventori" styleClass="nav-button" text="Inventori" />
            <Button onAction="#gotoSupplier" styleClass="nav-button" text="Supplier" />
            <Button onAction="#gotoLaporan" styleClass="nav-button" text="Laporan" />
            <Button onAction="#gotoRiwayat" styleClass="nav-button" text="Riwayat" />
            <Button onAction="#gotoPembelian" styleClass="nav-button" text="Pembelian" />
            <Region VBox.vgrow="ALWAYS" />
            <Button onAction="#handleLogout" styleClass="btn-logout" text="Log-Out" />
        </VBox>

        <VBox spacing="12" style="-fx-padding:16;" HBox.hgrow="ALWAYS">

            <HBox spacing="12">
                <VBox spacing="8" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="label-section" text="Tambah Barang" />
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <VBox spacing="2">
                            <Label styleClass="label-muted" text="Nama Barang" />
                            <ComboBox fx:id="cmbNamaBarang" editable="true" prefWidth="300" promptText="Ketik nama barang..." />
                        </VBox>
                        <VBox spacing="2">
                            <Label styleClass="label-muted" text="Jumlah" />
                            <TextField fx:id="txtJumlah" prefHeight="42.0" prefWidth="70" promptText="1" />
                        </VBox>
                        <VBox alignment="BOTTOM_LEFT">
                            <Button onAction="#handleTambahBarang" styleClass="btn-add-icon" text="+">
                        <VBox.margin>
                           <Insets bottom="12.0" />
                        </VBox.margin></Button>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox alignment="CENTER_LEFT" minWidth="180" spacing="4" styleClass="card">
                    <Label styleClass="label-section" text="Total" />
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <Label style="-fx-font-size:14px;-fx-font-weight:bold;" text="Rp" />
                        <Label fx:id="lblTotal" styleClass="label-total-value" text="0,00" />
                    </HBox>
                </VBox>
            </HBox>

            <VBox spacing="8" styleClass="card" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label styleClass="label-section" text="Daftar Belanja" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#handleHapusSemua" style="-fx-font-size:11px;" styleClass="btn-danger" text="Hapus Semua" />
                </HBox>
                <TableView fx:id="tblKeranjang" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNo" prefWidth="45" text="No" />
                        <TableColumn fx:id="colKode" prefWidth="100" text="Kode" />
                        <TableColumn fx:id="colNama" prefWidth="240" text="Nama Barang" />
                        <TableColumn fx:id="colHarga" prefWidth="110" text="Harga" />
                        <TableColumn fx:id="colQty" prefWidth="60" text="QTY" />
                        <TableColumn fx:id="colDiskon" prefWidth="75" text="Disc(%)" />
                        <TableColumn fx:id="colSubtotal" prefWidth="120" text="Sub Total" />
                        <TableColumn fx:id="colAksi" prefWidth="110" text="" />
                    </columns>
                </TableView>
            </VBox>

            <HBox spacing="12">
                <VBox prefWidth="210" spacing="8" styleClass="card">
                    <Label styleClass="label-section" text="Diskon" />
                    <Label styleClass="label-muted" text="Persentase Diskon" />
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <TextField fx:id="txtDiskon" prefWidth="80" promptText="0" />

                    </HBox>
                    <Button onAction="#handleTerapkanDiskon" styleClass="btn-secondary" text="Terapkan" />
                </VBox>

                <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                    <Label styleClass="label-section" text="Hitung Kembalian" />
                    <GridPane hgap="16" vgap="8">
                        <Label text="Cashless" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <ToggleButton fx:id="toggleCashless" onAction="#handleToggleCashless" text="OFF" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Label text="Nominal Bayar" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <HBox alignment="CENTER_LEFT" spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label style="-fx-font-weight:bold;" text="Rp" />
                            <TextField fx:id="txtNominalBayar" onKeyReleased="#hitungKembalianRealtime" prefWidth="160" promptText="0" />
                        </HBox>
                        <Label text="Kembalian" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <Label fx:id="lblKembalian" styleClass="label-kembalian" text="Rp 0,00" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  <columnConstraints>
                     <ColumnConstraints />
                     <ColumnConstraints />
                  </columnConstraints>
                  <rowConstraints>
                     <RowConstraints />
                     <RowConstraints />
                     <RowConstraints />
                  </rowConstraints>
                    </GridPane>
                </VBox>

                <VBox alignment="TOP_CENTER" prefWidth="210" spacing="10" styleClass="card">
                    <Label styleClass="label-section" text="Bayar dan Cetak Struk" />
                    <Button fx:id="btnBayar" onAction="#handleBayar" prefHeight="44" prefWidth="180" style="-fx-font-size:15px;" styleClass="btn-success" text="Bayar" />
                    <Button onAction="#handleBatalkan" prefWidth="180" styleClass="btn-danger" text="Batalkan Transaksi" />
                </VBox>
            </HBox>

        </VBox>
    </HBox>
</VBox>
